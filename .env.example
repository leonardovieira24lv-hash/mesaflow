# Supabase — projeto do MesaFlow
# Nunca commitar o .env.local real. Este arquivo é só o template.

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Somente uso em Route Handlers / server-side (nunca expor ao cliente).
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# URL pública da aplicação (usada para montar links de QR Code, ex.: {slug}/mesa/{token})
NEXT_PUBLIC_APP_URL=http://localhost:3000
